# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_PUBLISHABLE_KEY=tu_publishable_key
SUPABASE_SECRET_KEY=tu_secret_key
SUPABASE_JWKS_URL=https://tu-proyecto.supabase.co/auth/v1/.well-known/jwks.json

# PostgreSQL directo para asyncpg
# Usa el connection string de Supabase, no la URL del dashboard.
DATABASE_URL=postgresql://postgres:password@db.tu-proyecto.supabase.co:5432/postgres?sslmode=require

# Machine Learning
ML_MODELS_DIR=./ml_models
XGBOOST_MODEL_PATH=./ml_models/xgboost_demanda.joblib
LIGHTGBM_MODEL_PATH=./ml_models/lightgbm_prioridad.joblib

# App
APP_ENV=development
APP_CORS_ORIGINS=http://localhost:3000,https://tuapp.vercel.app
