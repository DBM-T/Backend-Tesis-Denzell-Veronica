# ── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# ── PostgreSQL directo (para consultas RNS complejas) ──────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── RNS ────────────────────────────────────────────────────────
RNS_MODEL_PATH=./rns_module/weights/sasnn_v1.pt
RNS_ENCODER_NAME=paraphrase-multilingual-MiniLM-L12-v2
RNS_SIMILARITY_THRESHOLD=0.85
RNS_TOP_K=5

# ── App ────────────────────────────────────────────────────────
APP_ENV=development           # development | production
APP_CORS_ORIGINS=http://localhost:3000,https://tuapp.vercel.app
